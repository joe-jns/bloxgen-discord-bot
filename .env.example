# Discord bot token (Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=

# Command prefix (optional, defaults to "+")
PREFIX=+

# Your BloxGen API key (Dashboard > Overview). Format: BLOX-xxxxxxxxxxxxxxxx
BLOXGEN_API_KEY=

# (Optional) Channel ID where each generation is logged (who, type, cost).
# Right-click a channel in Discord > Copy Channel ID (Developer Mode must be on).
LOG_CHANNEL_ID=
