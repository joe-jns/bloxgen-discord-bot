# Discord bot token (Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=

# Command prefix (optional, defaults to "+")
PREFIX=+

# Your BloxGen API key (Dashboard > Overview). Format: BLOX-xxxxxxxxxxxxxxxx
BLOXGEN_API_KEY=

# (Optional) Fallback log channel ID. You can also set this per server with the
# +logs command (which takes priority over this value). Leave empty to disable.
LOG_CHANNEL_ID=
