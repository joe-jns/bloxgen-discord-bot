# Discord bot token (Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=

# Command prefix (optional, defaults to "+")
PREFIX=+

# Your BloxGen API key (Dashboard > Overview). Format: BLOX-xxxxxxxxxxxxxxxx
BLOXGEN_API_KEY=

# Dashboard session cookie for the +history command (the official API has no history endpoint).
# Get it on https://bloxgen.net (logged in): F12 > Application > Cookies > https://bloxgen.net
# > copy the value of the "accessToken" cookie. Lasts ~7 days, so refresh it weekly.
BLOXGEN_SESSION_COOKIE=

# (Optional) Fallback log channel ID. You can also set this per server with the
# +logs command (which takes priority over this value). Leave empty to disable.
LOG_CHANNEL_ID=
